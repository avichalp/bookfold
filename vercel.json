{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build:vercel",
  "installCommand": "bun install",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/favicon.svg",
      "destination": "/api"
    },
    {
      "source": "/openapi.json",
      "destination": "/api"
    },
    {
      "source": "/llms.txt",
      "destination": "/api"
    },
    {
      "source": "/.well-known/x402",
      "destination": "/api"
    },
    {
      "source": "/.well-known/mpp-verify.txt",
      "destination": "/api"
    },
    {
      "source": "/healthz",
      "destination": "/api"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api"
    },
    {
      "source": "/.well-known/workflow/v1/webhook/:token",
      "destination": "/.well-known/workflow/v1/webhook/[token]"
    }
  ]
}
