{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/sdk": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/cli": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  }
}
